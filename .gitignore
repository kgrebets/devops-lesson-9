```gitignore
# Terraform working directory
.terraform/

# Terraform state files
*.tfstate
*.tfstate.*

# Terraform crash logs
crash.log
crash.*.log

# Terraform variable files
*.tfvars
*.tfvars.json

# Terraform override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Terraform plan files
*.tfplan

# CLI configuration files
.terraformrc
terraform.rc

# Sensitive files
*.pem
*.key

# IDE files
.vscode/
.idea/

# OS files
.DS_Store
Thumbs.db
```
